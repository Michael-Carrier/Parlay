        "emoji": "💬"
    },
    {
        "id": 309,
        "start": 738.24,
        "end": 741.24,
        "text": "But then came an elephant.",
        "emoji": "💬"
    },
    {
        "id": 310,
        "start": 741.24,
        "end": 744.88,
        "text": "Boom-ba-ba, boom-ba-ba, boom-ba-ba, boom!",
        "emoji": "💬"
    },
    {
        "id": 311,
        "start": 745.04,
