    },
    {
        "id": 318,
        "start": 763.56,
        "end": 764.76,
        "text": "Ribbit. - (LAUGHS)",
        "emoji": "💬"
    },
    {
        "id": 319,
        "start": 764.92,
        "end": 768.28,
        "text": "Ah, the frog’s gone and along comes a pussycat.",
        "emoji": "💬"
